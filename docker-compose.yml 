# ====================================================================
# AI HUMANIZER - DOCKER COMPOSE
# ====================================================================
# Complete production-ready deployment configuration
# Works on Windows, Linux, macOS - Phone compatible
# ====================================================================

version: '3.8'

services:
  # ====================================================================
  # MAIN API SERVICE
  # ====================================================================
  humanizer-api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: ai-humanizer-api
    restart: unless-stopped
    
    ports:
      - "8000:8000"
    
    environment:
      # Environment settings
      - ENVIRONMENT=production
      - DEBUG=false
      - RELOAD=false
      - LOG_LEVEL=INFO
      
      # API Keys (from .env file)
      - REWRITE_API_KEY=${REWRITE_API_KEY}
      - GEMINI_API_KEY=${GEMINI_API_KEY}
      - GROQ_API_KEY=${GROQ_API_KEY}
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      
      # Server settings
      - HOST=0.0.0.0
      - PORT=8000
      
      # Limits
      - MAX_TEXT_LENGTH=${MAX_TEXT_LENGTH:-5000}
      - MIN_TEXT_LENGTH=${MIN_TEXT_LENGTH:-10}
      - MAX_BATCH_SIZE=${MAX_BATCH_SIZE:-50}
      
      # Cache settings
      - CACHE_ENABLED=${CACHE_ENABLED:-true}
      - CACHE_TTL=${CACHE_TTL:-3600}
      - CACHE_MAX_SIZE=${CACHE_MAX_SIZE:-1000}
      
      # Rate limiting
      - RATE_LIMIT_REQUESTS=${RATE_LIMIT_REQUESTS:-60}
      - RATE_LIMIT_PERIOD=${RATE_LIMIT_PERIOD:-60}
      
      # Default settings
      - DEFAULT_TONE=${DEFAULT_TONE:-academic}
      - DEFAULT_STYLE=${DEFAULT_STYLE:-balanced}
      - DEFAULT_PRESERVE_TECHNICAL=${DEFAULT_PRESERVE_TECHNICAL:-true}
      
      # Security
      - SECRET_KEY=${SECRET_KEY:-change-this-in-production}
      - ALGORITHM=${ALGORITHM:-HS256}
      - ACCESS_TOKEN_EXPIRE_MINUTES=${ACCESS_TOKEN_EXPIRE_MINUTES:-30}
    
    env_file:
      - .env
    
    volumes:
      # Persistent logs
      - ./logs:/app/logs
      
      # Upload directory
      - ./uploads:/app/uploads
      
      # Word data (for better humanization)
      - ./backend/word_data:/app/backend/word_data
      
      # Don't mount code in production (use image)
    
    networks:
      - humanizer-network
    
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    
    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 512M

  # ====================================================================
  # REDIS CACHE (Optional - Uncomment if needed)
  # ====================================================================
  # redis:
  #   image: redis:7-alpine
  #   container_name: ai-humanizer-redis
  #   restart: unless-stopped
