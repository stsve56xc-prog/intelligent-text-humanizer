<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>AI Humanizer</title>

    <!-- ===== Google Font ===== -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet"/>

    <style>
        /* ============================================================
                   RESET & BASE
                   ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0d1117;
            color: #c9d1d9;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* ============================================================
                   CONTAINER
                   ============================================================ */
        .container {
            max-width: 960px;
            width: 100%;
            background: #161b22;
            border-radius: 20px;
            padding: 40px;
            border: 1px solid #30363d;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
            transition: all 0.3s ease;
        }

        /* ============================================================
                   HEADER
                   ============================================================ */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 6px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .header h1 {
            color: #58a6ff;
            font-size: 32px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header h1 span {
            font-size: 36px;
        }

        .badge {
            background: #238636;
            color: #fff;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .subtitle {
            color: #8b949e;
            margin-bottom: 28px;
            font-size: 15px;
            border-left: 3px solid #58a6ff;
            padding-left: 14px;
        }

        /* ============================================================
                   TEXTAREA
                   ============================================================ */
        .textarea-wrapper {
            position: relative;
        }

        textarea {
            width: 100%;
            height: 200px;
            padding: 16px;
            background: #0d1117;
            color: #c9d1d9;
            border: 1px solid #30363d;
            border-radius: 10px;
            font-size: 15px;
            font-family: inherit;
            resize: vertical;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
            line-height: 1.7;
        }

        textarea:focus {
            outline: none;
            border-color: #58a6ff;
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.15);
        }

        textarea::placeholder {
            color: #484f58;
        }

        .char-count {
            position: absolute;
            bottom: 12px;
            right: 16px;
            font-size: 12px;
            color: #484f58;
            background: #0d1117;
            padding: 2px 12px;
            border-radius: 12px;
            pointer-events: none;
        }

        /* ============================================================
                   CONTROLS
                   ============================================================ */
        .controls {
            display: flex;
            gap: 12px;
            margin: 18px 0;
            flex-wrap: wrap;
            align-items: center;
        }

        .controls label {
            font-size: 14px;
            color: #8b949e;
            font-weight: 500;
        }

        select,
        button {
            padding: 10px 18px;
            background: #21262d;
            color: #c9d1d9;
            border: 1px solid #30363d;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: inherit;
        }

        select:hover {
            border-color: #58a6ff;
        }

        select:focus {
            outline: none;
            border-color: #58a6ff;
        }

        button {
            background: #238636;
            color: #fff;
            border: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        button:hover {
            background: #2ea043;
            transform: translateY(-1px);
        }

        button:active {
            transform: translateY(0);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .btn-copy {
            background: #21262d;
            border: 1px solid #30363d;
            color: #c9d1d9;
        }

        .btn-copy:hover {
            background: #30363d;
            border-color: #58a6ff;
        }

        /* ============================================================
                   RESULT
                   ============================================================ */
        .result-container {
            margin-top: 20px;
            padding: 20px;
            background: #0d1117;
            border-radius: 10px;
            border: 1px solid #30363d;
            min-height: 100px;
            white-space: pre-wrap;
            line-height: 1.7;
            font-size: 15px;
            transition: border-color 0.3s ease;
            position: relative;
        }

        .result-container.has-result {
            border-color: #238636;
        }

        .result-placeholder {
            color: #484f58;
            font-style: italic;
        }

        .loading {
            color: #58a6ff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .loading::after {
            content: '';
            width: 18px;
            height: 18px;
            border: 2px solid #58a6ff;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .error {
            color: #f85149;
        }

        .success {
            color: #3fb950;
        }

        .result-actions {
            display: flex;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        /* ============================================================
                   STATS BAR
                   ============================================================ */
        .stats-bar {
            display: flex;
            gap: 20px;
            margin-top: 16px;
            flex-wrap: wrap;
            color: #8b949e;
            font-size: 13px;
        }

        .stats-bar .stat-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .stats-bar .stat-item .label {
            color: #484f58;
        }

        .stats-bar .stat-item .value {
            color: #c9d1d9;
            font-weight: 500;
        }

        /* ============================================================
                   RESPONSIVE
                   ============================================================ */
        @media (max-width: 640px) {
            .container {
                padding: 20px;
            }

            .header h1 {
                font-size: 24px;
            }

            .controls {
                flex-direction: column;
                align-items: stretch;
            }

            select,
            button {
                width: 100%;
                justify-content: center;
            }

            .stats-bar {
                flex-direction: column;
                gap: 6px;
            }
        }
    </style>
</head>

<body>
    <div class="container">

        <!-- ===== HEADER ===== -->
        <div class="header">
            <h1><span>🤖</span> AI Humanizer</h1>
            <span class="badge">✨ v2.0</span>
        </div>
        <p class="subtitle">Make AI-generated text sound human &amp; natural</p>

        <!-- ===== TEXTAREA ===== -->
        <div class="textarea-wrapper">
            <textarea id="inputText" placeholder="Paste your AI-generated text here..."></textarea>
            <span class="char-count" id="charCount">0 / 5000</span>
        </div>

        <!-- ===== CONTROLS ===== -->
        <div class="controls">
            <label for="toneSelect">Tone</label>
            <select id="toneSelect">
                <option value="academic">📚 Academic</option>
                <option value="natural" selected>🌱 Natural</option>
                <option value="blog">📝 Blog</option>
                <option value="professional">💼 Professional</option>
                <option value="conversational">💬 Conversational</option>
            </select>

            <label for="styleSelect">Style</label>
            <select id="styleSelect">
                <option value="conservative">🛡️ Conservative</option>
                <option value="balanced" selected>⚖️ Balanced</option>
                <option value="creative">🎨 Creative</option>
            </select>

            <button id="humanizeBtn">✨ Humanize</button>
            <button id="copyBtn" class="btn-copy" disabled>📋 Copy</button>
        </div>

        <!-- ===== RESULT ===== -->
        <div class="result-container" id="resultContainer">
            <span class="result-placeholder">Your humanized text will appear here...</span>
        </div>

        <!-- ===== STATS ===== -->
        <div class="stats-bar" id="statsBar">
            <span class="stat-item">
                <span class="label">📊 Words:</span>
                <span class="value" id="wordCount">0</span>
            </span>
            <span class="stat-item">
                <span class="label">⏱️ Time:</span>
                <span class="value" id="timeTaken">—</span>
            </span>
            <span class="stat-item">
                <span class="label">🔧 Method:</span>
                <span class="value" id="methodUsed">—</span>
            </span>
        </div>

    </div>

    <script>
        // ============================================================
        // DOM REFS
        // ============================================================
        const inputText = document.getElementById('inputText');
        const charCount = document.getElementById('charCount');
        const toneSelect = document.getElementById('toneSelect');
        const styleSelect = document.getElementById('styleSelect');
        const humanizeBtn = document.getElementById('humanizeBtn');
        const copyBtn = document.getElementById('copyBtn');
        const resultContainer = document.getElementById('resultContainer');
        const wordCount = document.getElementById('wordCount');
        const timeTaken = document.getElementById('timeTaken');
        const methodUsed = document.getElementById('methodUsed');

        // ============================================================
        // SAMPLE TEXT
        // ============================================================
        const SAMPLE_TEXT =
            `Microscopic identification was carried out to confirm morphological characteristics of purified fungal isolates. A small portion of fungal mycelium was placed on a clean glass slide, and a drop of lactophenol cotton blue (LPCB) stain was added. A cover slip was gently placed to avoid air bubbles. Prepared slides were observed under a compound light microscope at 10× and 40× magnifications. Key structural features such as hyphal type, septation, conidiophore structure, and spore morphology were recorded. Aspergillus niger was identified by septate hyphae and globose conidial heads with darkly pigmented spores. Trichoderma spp. showed branched conidiophores with clustered phialides and green spore masses, while Aspergillus terreus exhibited brush-like penicillus structures with chain-like spore arrangements. Microscopic observations, combined with colony morphology, were used for preliminary identification prior to consortium development and polymer degradation studies.`;

        // ============================================================
        // AUTO-LOAD SAMPLE
        // ============================================================
        if (!inputText.value) {
            inputText.value = SAMPLE_TEXT;
            updateCharCount();
        }

        // ============================================================
        // CHARACTER COUNT
        // ============================================================
        inputText.addEventListener('input', updateCharCount);

        function updateCharCount() {
            const len = inputText.value.length;
            charCount.textContent = `${len} / 5000`;
            charCount.style.color = len > 5000 ? '#f85149' : '#484f58';
        }

        // ============================================================
        // HUMANIZE
        // ============================================================
        humanizeBtn.addEventListener('click', humanize);

        // Ctrl+Enter shortcut
        inputText.addEventListener('keydown', (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                humanize();
            }
        });

        async function humanize() {
            const text = inputText.value.trim();
            if (!text) {
                resultContainer.innerHTML = `<span class="error">⚠️ Please paste some text first!</span>`;
                resultContainer.className = 'result-container';
                return;
            }

            if (text.length > 5000) {
                resultContainer.innerHTML =
                    `<span class="error">⚠️ Text exceeds 5000 characters (${text.length}). Please shorten it.</span>`;
                resultContainer.className = 'result-container';
                return;
            }

            // UI: loading state
            humanizeBtn.disabled = true;
            humanizeBtn.innerHTML = '⏳ Humanizing...';
            resultContainer.innerHTML = `<span class="loading">🔄 Processing your text...</span>`;
            resultContainer.className = 'result-container';
            copyBtn.disabled = true;
            wordCount.textContent = '…';
            timeTaken.textContent = '…';
            methodUsed.textContent = '…';

            const tone = toneSelect.value;
            const style = styleSelect.value;

            try {
                const start = performance.now();

                const response = await fetch('http://localhost:8000/api/humanize', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text, tone, style, preserve_technical: true }),
                });

                const end = performance.now();
                const elapsed = ((end - start) / 1000).toFixed(2);

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.detail || `Server error: ${response.status}`);
                }

                // Show result
                resultContainer.innerHTML = data.humanized_text;
                resultContainer.className = 'result-container has-result';
                copyBtn.disabled = false;

                // Stats
                wordCount.textContent = data.word_count || data.humanized_text.split(/\s+/).length;
                timeTaken.textContent = `${elapsed}s`;
                methodUsed.textContent = data.method_used || 'local';

            } catch (err) {
                resultContainer.innerHTML = `
                            <span class="error">❌ Error: ${err.message}</span>
                            <br><br>
                            <span style="color:#8b949e;font-size:14px;">
                                💡 Make sure the backend is running:<br>
                                <code style="background:#0d1117;padding:4px 8px;border-radius:4px;display:inline-block;margin-top:6px;">
                                    python -m backend.main
                                </code>
                            </span>
                        `;
                resultContainer.className = 'result-container';
                wordCount.textContent = '0';
                timeTaken.textContent = '—';
                methodUsed.textContent = '—';
            }

            humanizeBtn.disabled = false;
            humanizeBtn.innerHTML = '✨ Humanize';
        }

        // ============================================================
        // COPY
        // ============================================================
        copyBtn.addEventListener('click', copyResult);

        function copyResult() {
            const text = resultContainer.textContent;
            if (!text || text.includes('Your humanized text')) return;

            navigator.clipboard.writeText(text).then(() => {
                const original = copyBtn.innerHTML;
                copyBtn.innerHTML = '✅ Copied!';
                setTimeout(() => {
                    copyBtn.innerHTML = original;
                }, 2000);
            }).catch(() => {
                // Fallback
                const range = document.createRange();
                range.selectNode(resultContainer);
                window.getSelection().removeAllRanges();
                window.getSelection().addRange(range);
                document.execCommand('copy');
                window.getSelection().removeAllRanges();
                const original = copyBtn.innerHTML;
                copyBtn.innerHTML = '✅ Copied!';
                setTimeout(() => {
                    copyBtn.innerHTML = original;
                }, 2000);
            });
        }

        // ============================================================
        // KEYBOARD SHORTCUT: Escape to clear result
        // ============================================================
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !e.ctrlKey && !e.metaKey) {
                resultContainer.innerHTML = `<span class="result-placeholder">Your humanized text will appear here...</span>`;
                resultContainer.className = 'result-container';
                copyBtn.disabled = true;
                wordCount.textContent = '0';
                timeTaken.textContent = '—';
                methodUsed.textContent = '—';
            }
        });

        // ============================================================
        // INIT
        // ============================================================
        console.log('🤖 AI Humanizer frontend ready!');
        console.log('📡 Backend URL: http://localhost:8000');
        console.log('💡 Press Ctrl+Enter to humanize');
    </script>

</body>
</html>