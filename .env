# ====================================================================
# AI HUMANIZER - ENVIRONMENT VARIABLES (ACTUAL KEYS)
# ====================================================================
# This file contains REAL API keys - DO NOT SHARE!
# ====================================================================

# ====================================================================
# API KEYS (YOUR ACTUAL KEYS)
# ====================================================================

# RewriteAI API Key (Your actual key)
REWRITE_API_KEY=rw_sk_b571009ef578717e3c2832416e42a3da7a6dfef587e3fb22a4464d85431e46bc
REWRITE_API_URL=https://rewriteai.com/api/v1/humanize

# Gemini API Key (Get from ai.google.dev)
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent

# Groq API Key (Get from console.groq.com)
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI API Key (Optional - Paid)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-3.5-turbo

# ====================================================================
# API SETTINGS
# ====================================================================

API_TIMEOUT=30
API_CONNECT_TIMEOUT=10
MAX_RETRIES=3
RETRY_DELAY=1

# ====================================================================
# RATE LIMITING
# ====================================================================

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# ====================================================================
# TEXT LIMITS
# ====================================================================

MAX_TEXT_LENGTH=5000
MIN_TEXT_LENGTH=10
MAX_BATCH_SIZE=50

# ====================================================================
# DEFAULT SETTINGS
# ====================================================================

DEFAULT_TONE=academic
DEFAULT_STYLE=balanced
DEFAULT_PRESERVE_TECHNICAL=true

# ====================================================================
# SERVER SETTINGS
# ====================================================================

HOST=0.0.0.0
PORT=8000
DEBUG=true
RELOAD=true

# ====================================================================
# LOGGING
# ====================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ====================================================================
# CORS SETTINGS
# ====================================================================

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ====================================================================
# CACHE SETTINGS
# ====================================================================

CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ====================================================================
# ENVIRONMENT
# ====================================================================

ENVIRONMENT=development
CLOUD_PROVIDER=

# ====================================================================
# SECURITY
# ====================================================================

SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================================================================
# FEATURE FLAGS
# ====================================================================

FEATURE_BATCH_PROCESSING=true
FEATURE_TEXT_ANALYSIS=true
FEATURE_COMPARE_TONES=true
FEATURE_WORD_SUGGESTIONS=true

# ====================================================================
# VOCABULARY DATA
# ====================================================================

WORD_DATA_PATH=backend/word_data
LOAD_WORD_DATA=true
MAX_EMBEDDING_WORDS=100000

# ====================================================================
# END OF FILE
# ====================================================================