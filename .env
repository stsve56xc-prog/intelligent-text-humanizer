# ====================================================================
# AI HUMANIZER - ENVIRONMENT VARIABLES
# ====================================================================
# Copy this file and add your API keys
# Never commit this file to GitHub!

# ====================================================================
# API KEYS
# ====================================================================

# RewriteAI API Key (Get from rewriteai.com)
# Currently using your provided key
REWRITE_API_KEY=rw_sk_b571009ef578717e3c2832416e42a3da7a6dfef587e3fb22a4464d85431e46bc
REWRITE_API_URL=https://rewriteai.com/api/v1/humanize

# Gemini API Key (Get from ai.google.dev)
# Free tier: 60 requests per minute
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent

# Groq API Key (Get from console.groq.com)
# Free tier: 30 requests per minute
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI API Key (Optional - Paid)
# Get from platform.openai.com
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-3.5-turbo

# ====================================================================
# API SETTINGS
# ====================================================================

# Timeouts (in seconds)
API_TIMEOUT=30
API_CONNECT_TIMEOUT=10

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=1

# ====================================================================
# RATE LIMITING
# ====================================================================

# Maximum requests per time period
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# ====================================================================
# TEXT LIMITS
# ====================================================================

MAX_TEXT_LENGTH=5000
MIN_TEXT_LENGTH=10
MAX_BATCH_SIZE=50

# ====================================================================
# DEFAULT SETTINGS
# ====================================================================

# Available tones: academic, natural, blog, professional, conversational
DEFAULT_TONE=academic

# Available styles: conservative, balanced, creative
DEFAULT_STYLE=balanced

# Preserve technical/scientific terms
DEFAULT_PRESERVE_TECHNICAL=true

# ====================================================================
# SERVER SETTINGS
# ====================================================================

HOST=0.0.0.0
PORT=8000

# Debug mode (true for development)
DEBUG=true

# Auto-reload on file changes (development only)
RELOAD=true

# ====================================================================
# LOGGING
# ====================================================================

# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=logs/app.log

# Log format
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ====================================================================
# CORS SETTINGS
# ====================================================================

# Allowed origins (comma separated, * for all)
CORS_ALLOW_ORIGINS=*

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# Allowed methods (comma separated, * for all)
CORS_ALLOW_METHODS=*

# Allowed headers (comma separated, * for all)
CORS_ALLOW_HEADERS=*

# ====================================================================
# CACHE SETTINGS
# ====================================================================

# Enable/disable caching
CACHE_ENABLED=true

# Cache time-to-live in seconds (1 hour = 3600)
CACHE_TTL=3600

# Maximum number of items in cache
CACHE_MAX_SIZE=1000

# ====================================================================
# ENVIRONMENT
# ====================================================================

# Environment: development, production, testing
ENVIRONMENT=development

# Cloud provider if deployed (aws, gcp, azure, etc.)
CLOUD_PROVIDER=

# ====================================================================
# SECURITY
# ====================================================================

# Secret key for JWT (if authentication added later)
SECRET_KEY=your-secret-key-here-change-in-production

# Algorithm for JWT
ALGORITHM=HS256

# Access token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================================================================
# FILE STORAGE
# ====================================================================

# Upload directory
UPLOAD_DIR=uploads

# Maximum upload size (MB)
MAX_UPLOAD_SIZE=10

# Allowed file extensions for upload
ALLOWED_EXTENSIONS=.txt,.docx,.pdf

# ====================================================================
# DATABASE (Optional - for future)
# ====================================================================

# Database URL (if using database)
DATABASE_URL=

# ====================================================================
# EMAIL (Optional - for future)
# ====================================================================

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ====================================================================
# MONITORING (Optional)
# ====================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# New Relic license key
NEW_RELIC_LICENSE_KEY=

# ====================================================================
# FEATURE FLAGS
# ====================================================================

# Enable/disable features
FEATURE_BATCH_PROCESSING=true
FEATURE_TEXT_ANALYSIS=true
FEATURE_COMPARE_TONES=true
FEATURE_WORD_SUGGESTIONS=true

# ====================================================================
# VOCABULARY DATA
# ====================================================================

# Path to word data (relative to project root)
WORD_DATA_PATH=backend/word_data

# Enable/disable word data loading
LOAD_WORD_DATA=true

# Maximum words to load from embeddings
MAX_EMBEDDING_WORDS=100000

# ====================================================================
# END OF FILE
# ====================================================================