class TestHumanizeRequest:
    """Test HumanizeRequest model"""
    
    def test_valid_request(self):
        """Test valid humanize request"""
        request = HumanizeRequest(
            text="This is a test text for humanization.",
            tone=ToneEnum.ACADEMIC,
            style=StyleEnum.BALANCED,
            preserve_technical=True
        )
        assert request.text == "This is a test text for humanization."
        assert request.tone == ToneEnum.ACADEMIC
        assert request.style == StyleEnum.BALANCED
        assert request.preserve_technical is True
    
    def test_request_with_defaults(self):
        """Test request with default values"""
        request = HumanizeRequest(
            text="Test text."
        )
        assert request.text == "Test text."
        assert request.tone == ToneEnum.ACADEMIC  # Default
        assert request.style == StyleEnum.BALANCED  # Default
        assert request.preserve_technical is True  # Default
    
    def test_request_min_text_length(self):
        """Test request with minimum text length"""
        request = HumanizeRequest(text="Test text.")  # 10 chars
        assert len(request.text) >= 10
    
    def test_request_text_cleaning(self):
        """Test text cleaning removes extra whitespace"""
        request = HumanizeRequest(
            text="  This   has   extra   spaces.  "
        )
        assert request.text == "This has extra spaces."
    
    def test_request_text_too_short(self):
        """Test request with text too short"""
        with pytest.raises(ValueError):
            HumanizeRequest(text="Hi")  # 2 chars
    
    def test_request_empty_text(self):
        """Test request with empty text"""
        with pytest.raises(ValueError):
            HumanizeRequest(text="")
    
    def test_request_invalid_tone(self):
        """Test request with invalid tone"""
        with pytest.raises(ValueError):
            HumanizeRequest(
                text="Test text.",
                tone="invalid_tone"  # type: ignore
            )
    
    def test_request_invalid_style(self):
        """Test request with invalid style"""
        with pytest.raises(ValueError):
            HumanizeRequest(
                text="Test text.",
                style="invalid_style"  # type: ignore
            )
    
    def test_request_max_text_length(self):
        """Test request with maximum text length"""
        long_text = "a" * 5000
        request = HumanizeRequest(text=long_text)
        assert len(request.text) == 5000
    
    def test_request_exceeds_max_length(self):
        """Test request exceeds max length"""
        with pytest.raises(ValueError):
            HumanizeRequest(text="a" * 5001)
    
    def test_request_preserve_technical_default(self):
        """Test preserve_technical default is True"""
        request = HumanizeRequest(text="Test text.")
        assert request.preserve_technical is True
    
    def test_request_json_schema(self):
        """Test request has JSON schema"""
        assert hasattr(HumanizeRequest, "Config")
        config = HumanizeRequest.Config
        assert hasattr(config, "json_schema_extra")


class TestBatchHumanizeRequest:
    """Test BatchHumanizeRequest model"""
    
    def test_valid_batch_request(self):
        """Test valid batch request"""
        request = BatchHumanizeRequest(
            texts=["Text 1", "Text 2", "Text 3"],
            tone=ToneEnum.NATURAL,
            style=StyleEnum.CREATIVE,
            preserve_technical=False
        )
        assert len(request.texts) == 3
        assert request.tone == ToneEnum.NATURAL
        assert request.style == StyleEnum.CREATIVE
        assert request.preserve_technical is False
    
    def test_batch_request_with_defaults(self):
        """Test batch request with defaults"""
        request = BatchHumanizeRequest(
            texts=["Text 1", "Text 2"]
        )
        assert request.tone == ToneEnum.ACADEMIC  # Default
        assert request.style == StyleEnum.BALANCED  # Default
        assert request.preserve_technical is True  # Default
    
    def test_batch_request_empty_list(self):
        """Test batch request with empty list"""
        with pytest.raises(ValueError):
            BatchHumanizeRequest(texts=[])
    
    def test_batch_request_too_many(self):
        """Test batch request with too many texts"""
        with pytest.raises(ValueError):
            BatchHumanizeRequest(texts=["Text"] * 51)  # Max 50
    
    def test_batch_request_empty_text(self):
        """Test batch request with empty text"""
        with pytest.raises(ValueError):
            BatchHumanizeRequest(texts=["", "Text 2"])
    
    def test_batch_request_text_too_short(self):
        """Test batch request with text too short"""
        with pytest.raises(ValueError):
            BatchHumanizeRequest(texts=["Hi", "Text 2"])
    
    def test_batch_request_invalid_tone(self):
        """Test batch request with invalid tone"""
        with pytest.raises(ValueError):
            BatchHumanizeRequest(
                texts=["Text 1"],
                tone="invalid_tone"  # type: ignore
            )
    
    def test_batch_request_text_cleaning(self):
        """Test batch request text cleaning"""
        request = BatchHumanizeRequest(
            texts=["  Text 1  ", "  Text 2  "]
        )
        assert request.texts[0] == "Text 1"
        assert request.texts[1] == "Text 2"


