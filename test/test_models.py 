        )
        assert response.methods_available == []
        assert response.dependencies == {}
        assert isinstance(response.timestamp, datetime)
    
    def test_health_response_uptime_optional(self):
        """Test health response uptime is optional"""
        response = HealthResponse(
            status="healthy",
            version="2.0.0"
        )
        assert response.uptime_seconds is None


class TestErrorResponse:
