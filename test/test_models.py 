class TestHumanizeResponse:
    """Test HumanizeResponse model"""
    
    def test_valid_response(self):
        """Test valid response"""
        response = HumanizeResponse(
            original_text="Original text",
            humanized_text="Humanized text",
            tone="academic",
            style="balanced",
            word_count=3,
            processing_time=0.5,
            method_used="local"
        )
        assert response.original_text == "Original text"
        assert response.humanized_text == "Humanized text"
        assert response.tone == "academic"
        assert response.style == "balanced"
        assert response.word_count == 3
        assert response.processing_time == 0.5
        assert response.method_used == "local"
        assert isinstance(response.timestamp, datetime)
    
    def test_response_with_optional_fields(self):
        """Test response with optional fields"""
        response = HumanizeResponse(
            original_text="Original",
            humanized_text="Humanized",
            tone="academic",
            style="balanced",
            word_count=2,
            processing_time=0.1,
            method_used="local",
            changes_made=5,
            original_word_count=10
        )
        assert response.changes_made == 5
        assert response.original_word_count == 10
    
    def test_response_word_count_validation(self):
        """Test response word count validation"""
        with pytest.raises(ValueError):
            HumanizeResponse(
                original_text="Original",
                humanized_text="Humanized",
                tone="academic",
                style="balanced",
                word_count=0,  # Must be >= 1
                processing_time=0.1,
                method_used="local"
            )
    
    def test_response_processing_time_validation(self):
        """Test response processing time validation"""
        with pytest.raises(ValueError):
            HumanizeResponse(
                original_text="Original",
                humanized_text="Humanized",
                tone="academic",
                style="balanced",
                word_count=1,
                processing_time=-1,  # Must be >= 0
                method_used="local"
            )


class TestHealthResponse:
    """Test HealthResponse model"""
    
    def test_valid_health_response(self):
