# ====================================================================
# .dockerignore - Files to exclude from Docker image
# ====================================================================
# Complete list of files/folders to ignore when building Docker image
# ====================================================================

# ====================================================================
# PYTHON
# ====================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dylib
*.dll

# Virtual Environment
venv/
env/
.venv/
.env/

# ====================================================================
# IDE
# ====================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ====================================================================
# GIT
# ====================================================================
.git/
.gitignore
.gitattributes
.gitkeep

# ====================================================================
# LOGS
# ====================================================================
logs/
*.log
*.log.*

# ====================================================================
# UPLOADS
# ====================================================================
uploads/
temp/
tmp/
*.tmp

# ====================================================================
# WORD DATA (Large files - download at runtime)
# ====================================================================
backend/word_data/
*.bin
*.gz
*.zip
*.tar.gz
*.tar
*.7z
*.rar
*.txt
*.db
*.sqlite
*.sqlite3

# ====================================================================
# TESTS
# ====================================================================
tests/
*.test.py
*.spec.py
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage.xml
*.cover

# ====================================================================
# SCRIPTS
# ====================================================================
scripts/
setup.sh
*.sh

# ====================================================================
# DOCUMENTATION
# ====================================================================
docs/
*.md
!README.md
*.rst

# ====================================================================
# CI/CD
# ====================================================================
.github/
.gitlab/
.azure/
circle.yml
.travis.yml

# ====================================================================
# SECRETS
# ====================================================================
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer

# ====================================================================
# OS FILES
# ====================================================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.swo
*.swp

# ====================================================================
# BACKUP FILES
# ====================================================================
*.bak
*.backup
*.old
*.orig

# ====================================================================
# DEPLOYMENT
# ====================================================================
*.pid
*.lock
deploy/
k8s/
helm/